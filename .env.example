# Anthropic / Claude API key. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use. Good options:
#   claude-sonnet-4-6   (fast, great quality - recommended)
#   claude-opus-4-8     (highest quality, slower/pricier)
CLAUDE_MODEL=claude-sonnet-4-6

# Path to the pdflatex executable used to compile the resume to PDF.
# Leave as "pdflatex" if it is on your PATH.
PDFLATEX_PATH=pdflatex

# Web server port
PORT=5000
